{
  "name": "my-electron-app",
  "private": true,
  "version": "1.0.0",
  "description": "BillingPro - GST Invoice Manager",
  "author": "BillingPro <billingpro@example.com>",
  "homepage": "https://github.com/billingpro/app",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron .",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:win": "vite build && electron-builder --win",
    "dist:win:portable": "vite build && electron-builder --win portable",
    "dist:all": "vite build && electron-builder --linux --win"
  },
  "build": {
    "appId": "com.billingpro.app",
    "productName": "BillingPro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "icon": "public/icons.svg"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/vite": "^4.3.0",
    "antd": "^6.4.3",
    "dayjs": "^1.11.21",
    "dexie": "^4.4.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.3.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
